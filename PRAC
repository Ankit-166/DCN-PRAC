@GET
@Path("/view")
public String view() {
String r = "";
try {
ResultSet rs = con.createStatement()
.executeQuery("SELECT * FROM contacts");
while (rs.next())
r += rs.getInt(1) + " : " + rs.getString(2) + "\n";
