#include <GL/glut.h>

// Clipping window
float xmin = 100, ymin = 100, xmax = 300, ymax = 300;

// Line points
float x1 = 50, y1 = 50, x2 = 350, y2 = 350;

// Region codes
int getCode(float x, float y) {
    int code = 0;
    if (x < xmin) code = code | 1;   // LEFT
    if (x > xmax) code = code | 2;   // RIGHT
    if (y < ymin) code = code | 4;   // BOTTOM
    if (y > ymax) code = code | 8;   // TOP
    return code;
}
// Simple clipping
void clipLine() {
    int c1 = getCode(x1, y1);
    int c2 = getCode(x2, y2);
    float x, y;
    while (1) {
        // both inside
        if (c1 == 0 && c2 == 0) break;
        // both outside (reject)
        if (c1 & c2) return;
        int c = c1 ? c1 : c2;
        if (c & 8) { // TOP
            x = x1 + (x2 - x1) * (ymax - y1) / (y2 - y1);
            y = ymax;
        }
        else if (c & 4) { // BOTTOM
            x = x1 + (x2 - x1) * (ymin - y1) / (y2 - y1);
            y = ymin;
        }
        else if (c & 2) { // RIGHT
            y = y1 + (y2 - y1) * (xmax - x1) / (x2 - x1);
            x = xmax;
        }
        else { // LEFT
            y = y1 + (y2 - y1) * (xmin - x1) / (x2 - x1);
            x = xmin;
        }
        if (c == c1) {
            x1 = x; y1 = y;
            c1 = getCode(x1, y1);
        } else {
            x2 = x; y2 = y;
            c2 = getCode(x2, y2);
        }
    }
    // Draw clipped line
    glColor3f(0,1,0);
    glBegin(GL_LINES);
    glVertex2f(x1,y1);
    glVertex2f(x2,y2);
    glEnd();
}
void display() {
    glClear(GL_COLOR_BUFFER_BIT);
    // Window
    glColor3f(1,1,1);
    glBegin(GL_LINE_LOOP);
    glVertex2f(xmin,ymin);
    glVertex2f(xmax,ymin);
    glVertex2f(xmax,ymax);
    glVertex2f(xmin,ymax);
    glEnd();
    // Original line
    glColor3f(1,0,0);
    glBegin(GL_LINES);
    glVertex2f(50,50);
    glVertex2f(350,350);
    glEnd();
    // Clipping
    clipLine();
    glFlush();
}
void init() {
    glClearColor(0,0,0,1);
    gluOrtho2D(0,400,0,400);
}
int main(int argc,char** argv) {
    glutInit(&argc,argv);
    glutCreateWindow("Line Clipping");
    init();
    glutDisplayFunc(display);
    glutMainLoop();
}

