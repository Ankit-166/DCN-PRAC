void floodFill(int x, int y)
{
    float current[3];
    getPixel(x, y, current);

    if (current[0] == oldColor[0] &&
        current[1] == oldColor[1] &&
        current[2] == oldColor[2])
    {
        setPixel(x, y);
        floodFill(x + 1, y);
        floodFill(x - 1, y);
        floodFill(x, y + 1);
