// Function to draw triangle
void drawTriangle(float a1, float b1, float a2, float b2, float a3, float b3) {
    glBegin(GL_TRIANGLES);
    glVertex2f(a1, b1);
    glVertex2f(a2, b2);
    glVertex2f(a3, b3);
    glEnd();
}

void display() {
    glClear(GL_COLOR_BUFFER_BIT);

    // Original
    glColor3f(1, 0, 0);
    drawTriangle(x1, z1, x2, z2, x3, z3);

    // Translation
    glColor3f(0, 1, 0);
    drawTriangle(x1+100, z1+50, x2+100, z2+50, x3+100, z3+50);

    // Scaling
    glColor3f(0, 0, 1);
    drawTriangle(x1*1.5, z1*1.5, x2*1.5, z2*1.5, x3*1.5, z3*1.5);

    // Rotation
    float angle = 45 * 3.1416 / 180;

    float rx1 = x1*cos(angle) - z1*sin(angle);
    float rz1 = x1*sin(angle) + z1*cos(angle);

    float rx2 = x2*cos(angle) - z2*sin(angle);
    float rz2 = x2*sin(angle) + z2*cos(angle);

    float rx3 = x3*cos(angle) - z3*sin(angle);
    float rz3 = x3*sin(angle) + z3*cos(angle);

    glColor3f(1, 1, 0);
    drawTriangle(rx1, rz1, rx2, rz2, rx3, rz3);

    // Reflection (about X-axis)
    glColor3f(1, 0, 1);
    drawTriangle(x1, -z1, x2, -z2, x3, -z3);

    // Shearing (X-direction)
    float shx = 1;

    glColor3f(1, 0.5, 0);
    drawTriangle(
        x1 + shx*z1, z1,
        x2 + shx*z2, z2,
        x3 + shx*z3, z3
    );

    glFlush();
}
