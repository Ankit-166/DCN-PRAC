def lrc(data): 
    result = data[0] 
    for i in range(1, len(data)): 
        temp = "" 
        for j in range(len(data[i])): 
            if result[j] == data[i][j]: 
                temp += '0' 
            else: 
                temp += '1' 
        result = temp 
    return result 
# Example 
data = ["1101", "1011", "1001"] 
print("LRC:", lrc(data)) 

--------------10.CRC-----------
def xor(a, b): 
    result = "" 
    for i in range(1, len(b)): 
        if a[i] == b[i]: 
            result += "0" 
        else: 
            result += "1" 
    return result 
def mod2div(dividend, divisor): 
    pick = len(divisor) 
    tmp = dividend[0:pick] 
 
    while pick < len(dividend): 
        if tmp[0] == '1': 
            tmp = xor(divisor, tmp) + dividend[pick] 
        else: 
            tmp = xor('0'*pick, tmp) + dividend[pick] 
        pick += 1 
    if tmp[0] == '1': 
        tmp = xor(divisor, tmp) 
    else: 
        tmp = xor('0'*pick, tmp) 
    return tmp 
 
def encode(data, key): 
    appended = data + '0'*(len(key)-1) 
    remainder = mod2div(appended, key) 
    return data + remainder 
def check(data, key): 
remainder = mod2div(data, key) 
return remainder 
# Example 
data = "1101" 
key = "1011" 
