------------12.HAmming Code---------
def hamming_encode(data): 
    m = len(data) 
    r = 0 
    while (2**r < m + r + 1): 
        r += 1 
    res = ['0'] * (m + r) 
    j = 0 
    for i in range(1, len(res)+1): 
        if i & (i-1) != 0: 
            res[i-1] = data[j] 
            j += 1
    for i in range(r): 
        pos = 2**i 
        val = 0 
        for j in range(1, len(res)+1): 
            if j & pos: 
                val ^= int(res[j-1]) 
        res[pos-1] = str(val) 
return ''.join(res) 
# Example 
data = "1011" 
print("Hamming Code:", hamming_encode(data)) 
