#include <GL/glut.h>
#include <stdio.h>

typedef struct {
    float x, y;
} Point;

Point poly[10], newpoly[10];
int n = 4;   // number of polygon vertices

// Clipping window
float xmin = 100, ymin = 100, xmax = 300, ymax = 300;

// Draw polygon
void draw(Point p[], int n) {
    glBegin(GL_POLYGON);
    for (int i = 0; i < n; i++)
        glVertex2f(p[i].x, p[i].y);
    glEnd();
}
// Check inside (Left edge only for simplicity)
int inside(Point p) {
    return p.x >= xmin;
}
// Intersection with left edge
Point intersect(Point p1, Point p2) {
    Point p;
    float m = (p2.y - p1.y) / (p2.x - p1.x);
    p.x = xmin;
    p.y = p1.y + m * (xmin - p1.x);
    return p;
}
// Clipping (only LEFT edge for simplicity)
int clip() {
    int k = 0;
    for (int i = 0; i < n; i++) {
        Point curr = poly[i];
        Point prev = poly[(i + n - 1) % n];

        int curr_in = inside(curr);
        int prev_in = inside(prev);

        if (prev_in && curr_in) {
            newpoly[k++] = curr;
        }
        else if (!prev_in && curr_in) {
            newpoly[k++] = intersect(prev, curr);
            newpoly[k++] = curr;
        }
        else if (prev_in && !curr_in) {
            newpoly[k++] = intersect(prev, curr);
        }
    }
    return k;
}
// Display
void display() {
    glClear(GL_COLOR_BUFFER_BIT);
    // Draw clipping window
    glColor3f(1, 1, 1);
    glBegin(GL_LINE_LOOP);
        glVertex2f(xmin, ymin);
        glVertex2f(xmax, ymin);
        glVertex2f(xmax, ymax);
        glVertex2f(xmin, ymax);
    glEnd();
    // Original polygon
    glColor3f(1, 0, 0);
    draw(poly, n);
    // Clipping
    int newn = clip();
    // Clipped polygon
    glColor3f(0, 1, 0);
    draw(newpoly, newn);
    glFlush();
}
