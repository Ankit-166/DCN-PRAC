import socket
SERVER_HOST = '127.0.0.1'
SERVER_PORT = 8080
server_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
server_socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
server_socket.bind((SERVER_HOST, SERVER_PORT))
server_socket.listen(1)
print(f"Listening on http://{SERVER_HOST}:{SERVER_PORT}")
while True:
    client_connection, client_address = server_socket.accept()
    request = client_connection.recv(4096).decode()
    print(request)
    headers = request.splitlines()
    filename = headers[0].split()[1]
    if filename == '/':
        filename = '/index.html'
    try:
        with open('htdocs' + filename, 'r') as fin:
            content = fin.read()
        response = (
            "HTTP/1.1 200 OK\r\n"
            "Content-Type: text/html\r\n"
            f"Content-Length: {len(content)}\r\n"
            "Connection: close\r\n"
            "\r\n"
            + content
        )
    except FileNotFoundError:
        content = "File Not Found"
        response = (
            "HTTP/1.1 404 Not Found\r\n"
            "Content-Type: text/plain\r\n"
            f"Content-Length: {len(content)}\r\n"
            "Connection: close\r\n"
            "\r\n"
            + content
        )
    client_connection.sendall(response.encode())
    client_connection.close()

------------------------5.Character Count----------
def sender(data):
    # Calculate the length of the data
    count = len(data)
    # Create the frame (count + data)
    frame = str(count) + "|" + data
    print("Sender Side")
    print("Original Data:", data)
    print("Frame Sent:", frame)
    return frame
def receiver(frame):
    print("\nReceiver Side")
    # Split the frame into count and data
    count, data = frame.split("|")
    count = int(count)
    # Extract the data using the character count
    received_data = data[:count]
    print("Character Count:", count)
    print("Data Received:", received_data)


